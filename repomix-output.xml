    return checker

async def get_current_user_payload(
        credentials: HTTPAuthorizationCredentials=Depends(security)
)->dict:
    try:
        payload=decode_token(credentials.credentials)
        return payload
    except JWTError:
        raise HTTPException(
                status_code=status.HTTP_401_UNAUTHORIZED,
                detail="Invalid Token"
            )
</file>

