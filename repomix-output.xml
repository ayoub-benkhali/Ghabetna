        value: rolesAsync,
        builder: (roles) => roles.isEmpty
            ? _EmptyState(
                onAdd: () async {
                  await showDialog(
                    context: context,
                    builder: (_) => const _RoleFormDialog(),
                  );
                  ref.invalidate(rolesProvider);
                },
              )
